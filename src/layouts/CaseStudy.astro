---
import Layout from './Layout.astro'
import { SITE } from '../config'

interface Props {
  title: string
  tag: string
  metrics: { value: string; label: string }[]
}

const { title, tag, metrics } = Astro.props
---

<Layout title={title}>
  <a href="/" class="back">← Back</a>
  <article>
    <header>
      <span class="tag">{tag}</span>
      <h1>{title}</h1>
      <div class="metrics">
        {metrics.map(m => (
          <div class="metric">
            <span class="metric-value">{m.value}</span>
            <span class="metric-label">{m.label}</span>
          </div>
        ))}
      </div>
    </header>

    <slot />
  </article>
</Layout>

<style is:global>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
  }
.back { font-size: 14px; color: #666; transition: color 0.15s; display: inline-block; margin-bottom: 2rem; }
  .back:hover { color: #111; }
  .nav-link { font-size: 13px; color: #666; transition: color 0.15s; }
  .nav-link:hover { color: #111; }

  header { margin-bottom: 3rem; }

  .tag {
    display: inline-block;
    font-size: 11px;
    color: #999;
    background: #f4f4f4;
    border-radius: 4px;
    padding: 3px 8px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 28px;
    font-weight: 500;
    line-height: 1.25;
    margin-bottom: 2rem;
    max-width: 580px;
  }

  .metrics {
    display: flex;
    gap: 2rem;
    padding: 1.5rem;
    background: #f4f4f4;
    border-radius: 12px;
  }

  .metric { display: flex; flex-direction: column; gap: 4px; }
  .metric-value { font-size: 24px; font-weight: 500; }
  .metric-label { font-size: 12px; color: #999; }

  section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #e5e5e5;
  }
  section:last-child { border-bottom: none; }

  h2 {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 1rem;
  }

  section p { font-size: 15px; color: #666; margin-bottom: 0.75rem; }
  section p:last-child { margin-bottom: 0; }

  ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  ul li { font-size: 15px; color: #666; padding-left: 1rem; position: relative; }
  ul li::before { content: '—'; position: absolute; left: 0; color: #e5e5e5; }

  .flow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
  .flow-item { border: 1px solid #e5e5e5; border-radius: 10px; padding: 1.25rem; }
  .flow-label { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: #999; display: block; margin-bottom: 0.5rem; }
  .flow-item h3 { font-size: 14px; font-weight: 500; margin-bottom: 0.5rem; }
  .flow-item p { font-size: 13px; color: #666; margin-bottom: 0; }

  footer {
    display: flex;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
    margin-top: 2rem;
  }
  footer a { font-size: 14px; color: #666; transition: color 0.15s; }
  footer a:hover { color: #111; }

  @media (max-width: 520px) {
    .flow { grid-template-columns: 1fr; }
    h1 { font-size: 22px; }
  }
</style>