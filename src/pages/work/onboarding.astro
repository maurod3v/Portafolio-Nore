---
import CaseStudy from "../../layouts/CaseStudy.astro";

const metrics = [
  { value: "−75%", label: "Onboarding time" },
  { value: "20 → 5", label: "Days to activation" },
];
---

<CaseStudy
  title="Reducing student onboarding time by 75% — Poliglota"
  tag="EdTech · User activation"
  metrics={metrics}
>
  <section>
    <h2>Context</h2>
    <p>
      Poliglota is an online language learning platform. The student onboarding
      process took around 20 days and required a lot of manual coordination
      between students, coaches, and internal teams. Many students abandoned the
      process before experiencing the product.
    </p>
  </section>

  <section>
    <h2>Problem</h2>
    <ul>
      <li>Too long to activate — 20 days from enrollment to first class</li>
      <li>Too much manual work for coaches</li>
      <li>Students dropping off before their first class</li>
    </ul>
    <p>
      A key finding: all students followed the same onboarding path, regardless
      of their language level.
    </p>
  </section>

  <section>
    <h2>Discovery</h2>
    <ul>
      <li>Stakeholder interviews with internal teams</li>
      <li>User journey mapping</li>
      <li>Workflow analysis</li>
      <li>Requirement sessions with business stakeholders</li>
    </ul>
  </section>

  <section>
    <h2>Solution</h2>
    <p>
      I redesigned the onboarding flow with two paths based on language
      proficiency.
    </p>
    <div class="flow">
      <div class="flow-item">
        <span class="flow-label">Automated path</span>
        <h3>Beginner students (A1)</h3>
        <p>
          Completed an automated assessment through VideoAsk and went directly
          to course selection — no coach needed.
        </p>
      </div>
      <div class="flow-item">
        <span class="flow-label">Coach-assisted path</span>
        <h3>Advanced students</h3>
        <p>
          Connected to a coach through a scheduling integration linked to Google
          Calendar, removing manual coordination.
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2>My role</h2>
    <ul>
      <li>Product Discovery</li>
      <li>Requirement Definition</li>
      <li>User Journey Mapping</li>
      <li>Low and High Fidelity Wireframes</li>
      <li>Stakeholder Alignment</li>
      <li>Prioritization</li>
      <li>Delivery Coordination</li>
    </ul>
  </section>

  <section>
    <h2>Results</h2>
    <ul>
      <li>Onboarding time reduced from 20 days to 5</li>
      <li>Less operational workload for coaches</li>
      <li>More scalable process</li>
      <li>More self-service experience for students</li>
    </ul>
  </section>
</CaseStudy>
