---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";
---

<Layout title="Norelis Monsalve — Product Manager">
  <section class="hero">
    <p class="label">Product Manager</p>
    <h1>I turn complex processes into products that work.</h1>
    <p class="bio">
      5+ years building digital products across SaaS, FinTech, EdTech, and AI. I
      focus on the intersection of user needs, business goals, and operational
      efficiency.
    </p>
  </section>

  <section class="current-focus">
    <p class="label">Current focus</p>
    <div class="focus-grid">
      <div class="focus-item">
        <span class="focus-tag">Master's Degree</span>
        <h3>Business Process Management & Technologies</h3>
        <p class="focus-meta">University of Granada · Spain · 2025–2026</p>
        <p>
          Studying technology management, digital transformation, business
          process optimization, and data-driven decision making.
        </p>
      </div>
      <div class="focus-item">
        <span class="focus-tag">Internship</span>
        <h3>Product & Operations</h3>
        <p class="focus-meta">Sympathy for the Lawyer · Spain · 2026</p>
        <p>
          Supporting process optimization and AI implementation across legal,
          tax, and business operations teams. Working on contract review
          automation, internal workflow design, and platform support for
          Incentiva.
        </p>
        <p class="focus-tools">
          Claude · ChatGPT · Microsoft Copilot · Figma AI
        </p>
      </div>
    </div>
  </section>

  <section class="work">
    <p class="label">Case studies</p>

    <a href="/work/patentia" class="case-card">
      <span class="tag">AI Product · Intellectual Property</span>
      <h2>AI Patentability Assessment Platform — Patentia</h2>
      <p>
        Joined an AI startup at MVP stage to structure product discovery, define
        personas, and identify the core barrier slowing user adoption.
      </p>
      <div class="metrics">
        <span><strong>MVP</strong> stage</span>
        <span><strong>LLMs + n8n</strong></span>
      </div>
    </a>

    <a href="/work/onboarding" class="case-card">
      <span class="tag">EdTech · User activation</span>
      <h2>Reducing student onboarding time by 75% — Poliglota</h2>
      <p>
        Redesigned the enrollment flow by segmenting students based on language
        proficiency. Reduced onboarding from 20 days to 5.
      </p>
      <div class="metrics">
        <span><strong>−75%</strong> onboarding time</span>
        <span><strong>20 → 5</strong> days</span>
      </div>
    </a>

    <a href="/work/crm" class="case-card">
      <span class="tag">EdTech · Internal operations</span>
      <h2>CRM migration and sales process redesign — Poliglota</h2>
      <p>
        Led the migration from an internal CRM to HubSpot. Aligned 4 teams,
        preserved 7 years of commercial data, and achieved full adoption in less
        than one week.
      </p>
      <div class="metrics">
        <span><strong>40+</strong> users migrated</span>
        <span><strong>&lt;1 week</strong> adoption</span>
      </div>
    </a>
  </section>

  <section class="skills">
    <p class="label">Skills & Tools</p>
    <div class="skills-grid">
      <div class="skill-group">
        <h3>Product Management</h3>
        <p>
          Product Discovery · Strategy · Roadmapping · Backlog Management ·
          Prioritization · Agile Scrum · Stakeholder Management
        </p>
      </div>
      <div class="skill-group">
        <h3>User Experience</h3>
        <p>User Research · Journey Mapping · Wireframing · Prototyping</p>
      </div>
      <div class="skill-group">
        <h3>Operations & Process</h3>
        <p>
          Business Process Analysis · Workflow Optimization · Change Management
          · Digital Transformation
        </p>
      </div>
      <div class="skill-group">
        <h3>AI Product</h3>
        <p>
          Prompt Engineering · AI Workflow Design · AI Adoption Strategy · LLMs
          · n8n
        </p>
      </div>
    </div>
    <div class="tools">
      <span class="tool">Jira</span>
      <span class="tool">Figma</span>
      <span class="tool">Notion</span>
      <span class="tool">HubSpot</span>
      <span class="tool">ClickUp</span>
      <span class="tool">Hotjar</span>
      <span class="tool">Google Analytics</span>
      <span class="tool">Claude</span>
      <span class="tool">ChatGPT</span>
      <span class="tool">Microsoft Copilot</span>
      <span class="tool">n8n</span>
      <span class="tool">SharePoint</span>
    </div>
  </section>
</Layout>

<style>
  .hero {
    margin-bottom: 4rem;
  }

  .label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 32px;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    max-width: 560px;
  }

  .bio {
    font-size: 16px;
    color: #666;
    max-width: 520px;
  }

  .current-focus {
    margin-bottom: 4rem;
  }
  .current-focus .label {
    margin-bottom: 1.25rem;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .focus-item {
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .focus-tag {
    display: inline-block;
    font-size: 11px;
    color: #999;
    background: #f4f4f4;
    border-radius: 4px;
    padding: 3px 8px;
    margin-bottom: 0.75rem;
  }

  .focus-item h3 {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .focus-meta {
    font-size: 12px;
    color: #999;
    margin-bottom: 0.75rem;
  }

  .focus-item p {
    font-size: 13px;
    color: #666;
    line-height: 1.65;
  }

  .focus-tools {
    font-size: 12px;
    color: #999;
    margin-top: 0.75rem;
  }

  .work {
    margin-bottom: 4rem;
  }
  .work .label {
    margin-bottom: 1.25rem;
  }

  .case-card {
    display: block;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.15s;
  }
  .case-card:hover {
    border-color: #999;
  }

  .tag {
    display: inline-block;
    font-size: 11px;
    color: #999;
    background: #f4f4f4;
    border-radius: 4px;
    padding: 3px 8px;
    margin-bottom: 0.75rem;
  }

  .case-card h2 {
    font-size: 17px;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 0.5rem;
  }

  .case-card p {
    font-size: 14px;
    color: #666;
    margin-bottom: 1rem;
  }

  .metrics {
    display: flex;
    gap: 1.5rem;
  }
  .metrics span {
    font-size: 13px;
    color: #999;
  }
  .metrics strong {
    color: #111;
    font-weight: 500;
  }

  .skills {
    margin-bottom: 3rem;
  }
  .skills .label {
    margin-bottom: 1.25rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .skill-group {
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .skill-group h3 {
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .skill-group p {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }

  .tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool {
    font-size: 12px;
    color: #666;
    background: #f4f4f4;
    border-radius: 4px;
    padding: 4px 10px;
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 24px;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
